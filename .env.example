# MongoDB
MONGO_URL=mongodb://localhost:27017/sana-fathima-mansion

# NextAuth (required for login)
NEXTAUTH_SECRET=generate-with-openssl-rand-base64-32
NEXTAUTH_URL=http://localhost:3000

# Optional: Google sign-in
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=

# Optional: public house name fallback (overridden by DB after onboarding)
# NEXT_PUBLIC_HOUSE_NAME=SanaFathima Mansion

# After `npm run seed`, demo login (ledger + auth):
# Email: demo@sana.local
# Password: Demo12345!

# Optional: Cloudinary (expense bill images). Prefer the full URL from the dashboard:
# CLOUDINARY_URL=cloudinary://API_KEY:API_SECRET@your_cloud_name
# Or split (cloud name must match dashboard, typically lowercase):
# CLOUDINARY_CLOUD_NAME=
# CLOUDINARY_API_KEY=
# CLOUDINARY_API_SECRET=

# Optional: WhatsApp bot (see README). Only true|1|yes|on enables outbound notify calls.
# IS_WHATSAPP_BOT_ENABLED=false
# WHATSAPP_BOT_URL=http://localhost:3001
# WHATSAPP_BOT_API_KEY=shared-secret-with-whatsapp-bot
