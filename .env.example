# MongoDB
MONGO_URL=mongodb://localhost:27017/sana-fathima-mansion

# NextAuth (required for login)
NEXTAUTH_SECRET=generate-with-openssl-rand-base64-32
NEXTAUTH_URL=http://localhost:3000

# Optional: Google sign-in
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=

# Optional: public house name fallback (overridden by DB after onboarding)
# NEXT_PUBLIC_HOUSE_NAME=SanaFathima Mansion

# After `npm run seed`, demo login (ledger + auth):
# Email: demo@sana.local
# Password: Demo12345!

# Super admin (audit logs + privileged actions). Defaults to kavinkumar24@gmail.com if unset.
# SUPER_ADMIN_EMAIL=

# Optional: Cloudinary (expense bill images). Prefer the full URL from the dashboard:
# CLOUDINARY_URL=cloudinary://API_KEY:API_SECRET@your_cloud_name
# Or split (cloud name must match dashboard, typically lowercase):
# CLOUDINARY_CLOUD_NAME=
# CLOUDINARY_API_KEY=
# CLOUDINARY_API_SECRET=

# Destructive dev cleanup (preserves one login; see scripts/clean-db-dev.ts). Never set in production.
# ALLOW_DB_CLEAN=true
# Optional override for which Account email to keep (defaults SUPER_ADMIN_EMAIL or kkavinkumar24@gmail.com):
# PRESERVE_ACCOUNT_EMAIL=

# Optional: Telegram Bot API (group/user alerts). Both required to send.
# TELEGRAM_BOT_TOKEN=
# TELEGRAM_CHAT_ID=
# Optional: deep links in messages (falls back to NEXT_PUBLIC_APP_URL)
# APP_URL=https://your-domain.com

# Optional: SMTP email (invites, reminders, monthly summary)
# EMAIL_USER=you@gmail.com
# EMAIL_PASSWORD=app-password
# EMAIL_FROM=SanaFathima Mansion <you@gmail.com>
# EMAIL_HOST=smtp.gmail.com
# EMAIL_PORT=587

# Optional: shared secret for cron webhooks:
# POST /api/cron/reminders and /api/cron/monthly-summary with header x-cron-secret
# CRON_SECRET=strong-random-string
