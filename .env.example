# MongoDB (Atlas)
MONGO_URL=mongodb+srv://USER:PASSWORD@cluster.mongodb.net/?retryWrites=true&w=majority
MONGO_DB_NAME=sanaFathimaMansion

# Optional: shown in header
NEXT_PUBLIC_HOUSE_NAME=SanaFathima Mansion

# Cloudinary (bill uploads — optional)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# WhatsApp bot service (separate process: cd whatsapp-bot && npm run dev)
# Use the same WHATSAPP_BOT_API_KEY value in whatsapp-bot/.env
# Set to true | 1 | yes | on to send expense/settlement messages to the group; anything else = off
IS_WHATSAPP_BOT_ENABLED=false
WHATSAPP_BOT_URL=http://localhost:3001
WHATSAPP_BOT_API_KEY=
